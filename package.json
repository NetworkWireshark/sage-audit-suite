{
  "name": "sage-audit-suite",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "npm --prefix frontend run dev",
    "build:web": "npm --prefix frontend run build",
    "preview:web": "npm --prefix frontend run preview",
    "desktop": "electron .",
    "desktop:dev": "concurrently \"npm --prefix frontend run dev -- --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^42.0.1",
    "wait-on": "^8.0.3"
  }
}
