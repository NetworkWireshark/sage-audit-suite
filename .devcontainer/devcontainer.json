{
  "name": "Sage Audit Suite",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },
  "postCreateCommand": "python -m pip install --user -r requirements.txt && npm install && npm --prefix frontend install",
  "forwardPorts": [5173, 8000],
  "portsAttributes": {
    "5173": {
      "label": "Sage Audit Suite Web",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "FastAPI Backend",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
